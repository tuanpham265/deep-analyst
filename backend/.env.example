# OpenCode Zen API credentials — register at https://opencode.ai/auth
OPENCODE_ZEN_API_KEY=sk-your-key-here

# Free models on OpenCode Zen (verified via GET /v1/models on 2026-05-28):
#   qwen3.6-plus-free, minimax-m2.5-free, deepseek-v4-flash-free,
#   mimo-v2.5-free, nemotron-3-super-free
# LiteLLM model ID format is "openai/<model-id>" since OpenCode Zen is OpenAI-compatible.
OPENHANDS_MODEL=openai/qwen3.6-plus-free
OPENHANDS_BASE_URL=https://opencode.ai/zen/v1

# Server settings
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173

# Set to 1 to suppress the OpenHands SDK startup banner
OPENHANDS_SUPPRESS_BANNER=1
